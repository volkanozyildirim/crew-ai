# ══════════════════════════════════════════════════════════════
# Azure DevOps
# ══════════════════════════════════════════════════════════════

# Organizasyon URL'i — https://dev.azure.com/<org> formatinda
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-organization

# Personal Access Token — Code (Read/Write), Work Items (Read/Write/Manage),
# Pull Requests (Read/Write) ve Build (Read) izinleri gerekli
AZURE_DEVOPS_PAT=your-personal-access-token

# Is kalemlerinin takip edildigi proje adi
AZURE_DEVOPS_PROJECT=your-project-name

# Repolar farkli bir projede bulunuyorsa proje adi (bos birakilirsa AZURE_DEVOPS_PROJECT kullanilir)
# Birden fazla proje icin virgülle ayir: ProjectA,ProjectB
AZURE_DEVOPS_REPO_PROJECTS=

# Sprint/backlog sorgularinda kullanilan takim adi
# Bos birakilirsa Azure DevOps varsayilan takimi kullanilir
AZURE_DEVOPS_TEAM=

# ══════════════════════════════════════════════════════════════
# HAL (isteğe bagli — HAL modu aktifse gerekli)
# ══════════════════════════════════════════════════════════════

# HAL API endpoint URL'i
HAL_BASE_URL=https://your-hal-endpoint.example.com

# HAL hesap bilgileri
HAL_EMAIL=your-hal-email
HAL_PASSWORD=your-hal-password

# ══════════════════════════════════════════════════════════════
# LLM Provider — hangi backend kullanilacak
# ══════════════════════════════════════════════════════════════

# ── Eski global provider secimi (geriye uyumluluk icin korunuyor) ──
# Provider secimi: litellm (varsayilan) | anthropic | claude-cli
# YENI MIMARIDE bu degisken `_create_llm()` legacy wrapper'ini etkiler;
# agent-bazli LLM secimi icin asagidaki CREW_LLM_PROFILE_* env'lerini kullanin.
CREW_LLM_PROVIDER=litellm

# ── Yeni: Agent-bazli LLM profilleri (config/llm_profiles.yaml) ──
#
# Cozumleme onceligi: env > agents.yaml `llm_profile:` > CREW_USE_LOCAL_LLM
#                     > agent_defaults
#
# Tanimli profiller (config/llm_profiles.yaml):
#   architect_premium, developer_premium, reviewer_premium,
#   reasoning_remote, scrum_remote,
#   reasoning_local, scrum_local, developer_local_coder, kickoff_local,
#   developer_cli, architect_cli, reasoning_cli,
#   developer_anthropic
#
# Ornek per-agent override'lar (yorum satirlari — istege gore aktiflestir):
# CREW_LLM_PROFILE_SOFTWARE_ARCHITECT=architect_premium
# CREW_LLM_PROFILE_SENIOR_DEVELOPER=developer_cli
# CREW_LLM_PROFILE_BUSINESS_ANALYST=reasoning_remote
# CREW_LLM_PROFILE_QA_ENGINEER=reasoning_local
# CREW_LLM_PROFILE_UAT_SPECIALIST=reasoning_local
# CREW_LLM_PROFILE_CODE_REVIEWER=reviewer_premium
# CREW_LLM_PROFILE_SCRUM_MASTER=scrum_local

# ── LiteLLM Proxy ──────────────────────────────────────────

# LiteLLM proxy adres ve kimlik dogrulama
LITELLM_BASE_URL=https://your-litellm-endpoint.com
LITELLM_API_KEY=your-litellm-api-key

# Architect/Developer disindaki agentlar icin varsayilan model
# Ornek: openai/gpt-4, vertex_ai/claude-sonnet-4-6, azure/gpt-4o
LITELLM_MODEL=openai/gpt-4

# ── Anthropic API (CREW_LLM_PROVIDER=anthropic ise) ────────

ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Ollama (local LLM) ──────────────────────────────────────

# Ollama sunucu adresi (varsayilan: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ══════════════════════════════════════════════════════════════
# Local LLM Kullanimı
# ══════════════════════════════════════════════════════════════

# BA, SM, Reviewer, QA, UAT agentlari icin Ollama kullanilsin mi?
# 1 / true / yes = aktif; bos birakilirsa devre disi (remote LLM kullanilir)
CREW_USE_LOCAL_LLM=

# BA/SM/Reviewer/QA/UAT icin muhakeme modeli (varsayilan: qwen3:8b)
# Türkçe instruct destekleyen bir model secilmeli
CREW_LOCAL_LLM_MODEL=qwen3:8b

# Developer (kod yazma) icin model (varsayilan: qwen2.5-coder:7b)
# Kod uretme için optimize edilmis bir model olmali
CREW_LOCAL_CODER_MODEL=qwen2.5-coder:7b

# Developer agent icin local model devre disi birak — Sonnet kullanilsin
# 0 / false / no = Developer agent remote LLM kullanir (varsayilan: 1 = local)
CREW_LOCAL_DEVELOPER=1

# WI görsel/link analizi icin Ollama vision modeli kullanilsin mi?
# 1 / true / yes = aktif; bos birakilirsa remote (LITELLM_MODEL) kullanilir
CREW_USE_LOCAL_VISION=

# Vision analizi icin Ollama modeli (varsayilan: qwen2.5vl:7b)
CREW_LOCAL_VISION_MODEL=qwen2.5vl:7b

# ══════════════════════════════════════════════════════════════
# MySQL Veritabani
# ══════════════════════════════════════════════════════════════

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=agile_sdlc_crew

# ══════════════════════════════════════════════════════════════
# Pipeline Davranisi
# ══════════════════════════════════════════════════════════════

# Repolarin clone edildigi yerel dizin (varsayilan: ~/.crew_repos)
CREW_REPOS_DIR=~/.crew_repos

# Semantik arama icin vektör veritabani yolu (varsayilan: ~/.crew_repos/.vectordb)
CREW_VECTOR_DB=~/.crew_repos/.vectordb

# ── Maliyet Kontrolu ───────────────────────────────────────

# Is basina maksimum harcama limiti (USD, varsayilan: 3.0)
# Asildigi an pipeline durdurulur ve WI'ya yorum atilir
CREW_MAX_JOB_COST=3.0

# Token fiyatlandirmasi — maliyet hesabi icin (varsayilan degerler Sonnet 4 fiyatlari)
# Input: $3/M token, Output: $15/M token
CREW_PRICE_INPUT_USD_PER_M=3.0
CREW_PRICE_OUTPUT_USD_PER_M=15.0

# ── Pipeline Ozellik Anahtarlari ───────────────────────────

# Kickoff toplantisi: her isten once tum agentlar birlikte calisar
# 1 = aktif (varsayilan), 0 = devre disi
CREW_KICKOFF_MEETING=1

# Her adim sonrasi Scrum Master kalite incelemesi
# Herhangi bir deger = aktif; bos birakilirsa devre disi (varsayilan: kapali)
# Dikkat: her adimda ek bir LLM cagrisı yapar — maliyet arttirir
CREW_SM_REVIEW=

# WI description'daki gorsel ve linkleri analiz et (varsayilan: 1 = aktif)
# 0 = devre disi
CREW_ANALYZE_WI_MEDIA=1

# WI icerik minimum karakter esigi — bu kadar plain text yoksa pipeline baslamaz
# (varsayilan: 100)
CREW_MIN_WI_CONTENT_CHARS=100
